(defmodule web-bml-test (:use web/bml) (:use web/template) (:use test))

; Render a parsed BML form against `model` — the same lowering `deflive` uses.
(defn render-bml (src model)
  (render (eval (list 'let (list 'model model) (parse src)))))

; A trivial component for the component tests: an assigns-map → Hiccup function.
(defn card (assigns)
  [:div {:class "card"} [:h2 {} (get assigns :title)] (get assigns :children)])

; Render BML with `card` (and `model`) in scope, so components resolve.
(defn render-bml* (src model)
  (render (eval (list 'let (list 'model model 'card card) (parse src)))))

(defn parse-error (src)
  (try (do (parse src) nil) (catch e (error-message e))))

(describe "parse — structure"
  (test "element with attr + text"
    (assert= (parse "<p class=\"a\">hi</p>") [:p {:class "a"} "hi"]))
  (test "bare attribute is boolean true"
    (assert= (parse "<input disabled>") [:input {:disabled true}]))
  (test "self-closing tag"
    (assert= (parse "<br/>") [:br {}]))
  (test "void tag needs no close"
    (assert= (parse "<img src=\"x\">") [:img {:src "x"}]))
  (test "whitespace-only text between tags is dropped"
    (assert= (parse "<ul>\n  <li>x</li>\n</ul>") [:ul {} [:li {} "x"]]))
  (test "interpolation becomes a form"
    (assert= (parse "<p>{(get model :n)}</p>") [:p {} (list 'get 'model :n)]))
  (test "braced attribute value becomes a form"
    (assert= (parse "<a href={u}>x</a>") [:a {:href 'u} "x"])))

(describe "parse — @name assign shorthand"
  (test "@name in text expands to (get model :name)"
    (assert= (parse "<p>{@count}</p>") [:p {} (list 'get 'model :count)]))
  (test "@name inside a larger expression"
    (assert= (parse "<p>{(inc @count)}</p>") [:p {} (list 'inc (list 'get 'model :count))]))
  (test "@kebab-name keeps the dashes"
    (assert= (parse "<p>{@user-name}</p>") [:p {} (list 'get 'model :user-name)]))
  (test "@ inside a string literal is left alone"
    (assert= (parse "<p>{(str \"a@b\")}</p>") [:p {} (list 'str "a@b")])))

(describe "parse — attribute interpolation"
  (test "mixed literal + {…} becomes a (str …)"
    (assert= (parse "<a class=\"btn {@kind}\">x</a>")
      [:a {:class (list 'str "btn " (list 'get 'model :kind))} "x"]))
  (test "a quoted value that is exactly {…} is the bare expression"
    (assert= (parse "<a class=\"{@kind}\">x</a>") [:a {:class (list 'get 'model :kind)} "x"]))
  (test "a plain quoted value stays a string"
    (assert= (parse "<a class=\"btn\">x</a>") [:a {:class "btn"} "x"]))
  (test "an interpolation may contain Brood strings (inner quotes don't end the attr)"
    (assert= (render-bml "<p style=\"c:{(if @on \"red\" \"blue\")}\">x</p>" {:on true})
      "<p style=\"c:red\">x</p>")))

(describe "parse — directives (brace syntax)"
  (test ":for wraps the element in a for"
    (assert= (parse "<li :for={x <- xs}>{x}</li>")
      (list 'for (list 'x 'xs) [:li {} 'x])))
  (test ":for over @items expands the collection"
    (assert= (parse "<li :for={x <- @items}>{x}</li>")
      (list 'for (list 'x (list 'get 'model :items)) [:li {} 'x])))
  (test ":if wraps the element in an if"
    (assert= (parse "<p :if={flag}>y</p>")
      (list 'if 'flag [:p {} "y"] nil)))
  (test ":if + :for becomes a per-item :when on the comprehension"
    (assert= (parse "<li :for={x <- xs} :if={(even? x)}>{x}</li>")
      (list 'for (list 'x 'xs :when (list 'even? 'x)) [:li {} 'x])))
  (test "a directive without a brace value errors"
    (assert-error (parse "<p :if=\"flag\">y</p>"))))

(describe "render — end to end"
  (test "@name renders the model value"
    (assert= (render-bml "<p>{@n}</p>" {:n 42}) "<p>42</p>"))
  (test "attribute interpolation renders"
    (assert= (render-bml "<a class=\"btn {@kind}\">x</a>" {:kind "primary"})
      "<a class=\"btn primary\">x</a>"))
  (test ":for renders one node per item"
    (assert= (render-bml "<ul><li :for={x <- @xs}>{x}</li></ul>" {:xs [1 2 3]})
      "<ul><li>1</li><li>2</li><li>3</li></ul>"))
  (test ":if false renders nothing"
    (assert= (render-bml "<p :if={@show}>hi</p>" {:show false}) ""))
  (test ":if + :for filters per item (test sees the loop binding)"
    (assert= (render-bml "<li :for={x <- @xs} :if={(even? x)}>{x}</li>" {:xs [1 2 3 4]})
      "<li>2</li><li>4</li>"))
  (test "text is HTML-escaped"
    (assert= (render-bml "<p>{@s}</p>" {:s "<b>"}) "<p>&lt;b&gt;</p>"))
  (test "raw opts out of escaping"
    ; render-bml evals at root, so qualify raw; in a view module `(:use web/template)`
    ; lets a template write `{(raw …)}` bare.
    (assert= (render-bml "<p>{(web/template/raw @s)}</p>" {:s "<b>"}) "<p><b></p>")))

(describe "raw-text elements + brace escapes"
  (test "<style> content is verbatim and unescaped"
    (assert= (render-bml "<style>.x { color: red }</style>" {})
      "<style>.x { color: red }</style>"))
  (test "<script> content is verbatim (no interpolation)"
    (assert= (render-bml "<script>if (a > 1) { f() }</script>" {})
      "<script>if (a > 1) { f() }</script>"))
  (test "\\{ and \\} are literal braces in text"
    (assert= (render-bml "<p>use \\{x\\} here</p>" {}) "<p>use {x} here</p>"))
  (test "\\{ is a literal brace in an attribute value"
    (assert= (parse "<a data-t=\"a\\{b\">x</a>") [:a {:data-t "a{b"} "x"])))

(describe "components"
  (test "self-closing component compiles to a call with an assigns map"
    (assert= (parse "<.card title=\"Hi\"/>") (list 'card {:title "Hi"})))
  (test "children are passed as the :children assign"
    (assert= (parse "<.card title=\"Hi\"><p>body</p></.card>")
      (list 'card {:title "Hi" :children (list 'list [:p {} "body"])})))
  (test "a component renders by calling its function"
    (assert= (render-bml* "<.card title=\"Pricing\"><p>body</p></.card>" {})
      "<div class=\"card\"><h2>Pricing</h2><p>body</p></div>"))
  (test "component attributes interpolate"
    (assert= (render-bml* "<.card title={@t}/>" {:t "Dyn"})
      "<div class=\"card\"><h2>Dyn</h2></div>")))

(describe "error locations"
  (test "unterminated interpolation reports line:col"
    (assert= (parse-error "<p>{x</p>") "bml:1:5: unterminated { interpolation"))
  (test "mismatched close tag reports line:col"
    (assert= (parse-error "<div>\n  <p>hi</div>")
      "bml:2:8: </div> closes the wrong tag, expected </p>"))
  (test "a directive without a brace value reports line:col"
    (assert= (parse-error "<p :if=\"x\">y</p>")
      "bml:1:8: directive :if needs a brace value, e.g. :if={…}")))
