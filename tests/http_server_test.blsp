(defmodule http-server-test
  ; server/start, server/stop
  (:alias http/server)
  ; parse-frame, byte->char
  (:use http/websocket)
  (:use test))

; Regression test for the WebSocket binary-mode race.
;
; The bug: `http/server`'s upgrade path sent the 101 and handed off to the ws-handler
; while the socket was still in *text* mode. The ws-handler (a live session) only
; flipped the socket to binary AFTER a registry lookup — so a client frame that arrived
; in that window was decoded UTF-8-lossy, turning every non-UTF-8 frame byte (0x81, the
; mask, the masked payload) into U+FFFD (codepoint 65533). `parse-frame` then read
; garbage lengths and looped on `:incomplete` forever, and the session went deaf.
;
; The fix: set the socket to binary BEFORE sending the 101 (the client can't send a
; frame until it sees the 101). This test pins that invariant: the ws-handler below
; deliberately does NOT call `tcp-set-binary` itself, so a frame with a high byte is
; delivered byte-faithfully ONLY because the upgrade path already switched to binary.
; Revert the fix and `read-one-frame` sees U+FFFD → `:incomplete` → times out.

(defn read-one-frame (sock buf)
  "Block until one complete WebSocket frame is buffered; return its decoded payload,
  or :timeout / :closed. Mirrors the live session's read loop, minus the dispatch."
  (match (parse-frame buf)
    ([:ok _opcode payload _rem] payload)
    ([:incomplete] (receive
                     ; binary-mode socket: `chunk` is a `bytes` value — convert to the
                     ; Latin-1 carrier before feeding the string-based parser
                     ([:tcp ~sock chunk] (read-one-frame sock (str buf (bytes->carrier chunk))))
                     ([:tcp-closed ~sock] :closed)
                     (after 2000 :timeout)))
    ([:error _m] :error)))

(defn echo-one-frame (reporter)
  "A ws-handler that reads one client frame and reports its payload to `reporter`.
  Crucially it never calls tcp-set-binary — the upgrade path must have done so."
  (fn (sock _request)
    (send reporter [:got (read-one-frame sock "")])))

(defn await-101 (sock buf)
  "Read from `sock` until the 101 handshake response (its header terminator) arrives."
  (if (includes? buf "\r\n\r\n")
    buf
    (receive
      ([:tcp ~sock chunk] (await-101 sock (str buf chunk)))
      (after 2000 :timeout))))

(defn ws-client-connect (port)
  "Open a raw client socket, send a WebSocket upgrade request, wait for the 101, then
  switch the client side to binary so it can send raw frame bytes. Returns the socket."
  (let (sock (tcp-connect "127.0.0.1" port)
        _req (tcp-send sock
               (str "GET /ws HTTP/1.1\r\n"
                 "Host: localhost\r\n"
                 "Upgrade: websocket\r\n"
                 "Connection: Upgrade\r\n"
                 "Sec-WebSocket-Key: dGhlIHNhbXBsZSBub25jZQ==\r\n"
                 "Sec-WebSocket-Version: 13\r\n\r\n"))
        _ack (await-101 sock ""))
    (tcp-set-binary sock true)
    sock))

(defn masked-byte-frame (b)
  "A single-byte-payload masked client text frame carrying byte `b` (mask key all
  zeros, so the masked payload byte equals `b`): 0x81, 0x80|1, 00 00 00 00, b."
  (str (byte->char 129)
    (byte->char 129)
    (byte->char 0)
    (byte->char 0)
    (byte->char 0)
    (byte->char 0)
    (byte->char b)))

(describe "websocket upgrade sets binary mode before the handler reads"
  ; One server, started and stopped within the test. Fixed obscure port; the handler
  ; reports the decoded payload back to this (the test) process.
  (test "a client frame's high byte arrives byte-faithful (not U+FFFD)"
    (let (me (self)
          port 54731
          _sup (server/start port
                 (fn (_req) {:status 200 :headers {} :body "ok"})
                 (echo-one-frame me))
          client (ws-client-connect port)
          _send (tcp-send client (masked-byte-frame 255))
          payload (receive ([:got p] p) (after 3000 :timeout)))
      (tcp-close client)
      (server/stop port)
      ; Before the fix: payload would be :timeout (frame read as U+FFFD → :incomplete).
      (assert= (string? payload) true)
      (assert= (string-length payload) 1)
      (assert= (byte-at payload 0) 255))))

(defn drain (sock buf)
  "Collect everything `sock` sends until it goes idle (keep-alive leaves it open), so a
  test can assert on the whole response — headers and body."
  (receive
    ([:tcp ~sock chunk] (drain sock (str buf chunk)))
    ([:tcp-closed ~sock] buf)
    (after 400 buf)))

(defn get-response (port path)
  "Open a client, send one GET (Connection: close, so the worker closes + exits once it
  has answered), and return the full raw response string."
  (let (sock (tcp-connect "127.0.0.1" port)
        _req (tcp-send sock
               (str "GET " path " HTTP/1.1\r\nHost: localhost\r\nConnection: close\r\n\r\n"))
        resp (drain sock ""))
    (tcp-close sock)
    resp))

(defn report-response (port me)
  "Run `get-response` in this (spawned) process and report the result to `me` — lets a
  test fire a request, then act (e.g. call `stop`) while it's in flight."
  (send me [:resp (get-response port "/")]))

(defn raw-response (port raw)
  "Send an arbitrary (possibly malformed) request string and return the full raw response."
  (let (sock (tcp-connect "127.0.0.1" port)
        _req (tcp-send sock raw)
        resp (drain sock ""))
    (tcp-close sock)
    resp))

; Tier-2 (docs/robustness.md): a handler that raises must answer a generic 500 without
; leaking internals; the detail is left to telemetry / the :error-handler knob.
(describe "a raising handler doesn't leak internals (default :error-handler)"
  (test "answers a generic 500 with the exception text NOT in the body"
    (let (port 54741
          _sup (server/start port (fn (_req) (error "SECRET-internal-detail")))
          resp (get-response port "/"))
      (server/stop port)
      (assert= (includes? resp "500") true)
      (assert= (includes? resp "SECRET-internal-detail") false))))

(describe "a custom :error-handler overrides the 500 response"
  (test "the configured handler's response is sent"
    (let (port 54742
          _sup (server/start port
                 (fn (_req) (error "boom"))
                 nil
                 {:error-handler (fn (_req _err) {:status 503 :headers {} :body "maintenance"})})
          resp (get-response port "/"))
      (server/stop port)
      (assert= (includes? resp "503") true)
      (assert= (includes? resp "maintenance") true))))

; A malformed request must answer a generic 400 without echoing the (attacker-controlled)
; request line back into the body.
(describe "a malformed request doesn't reflect attacker bytes"
  (test "answers a generic 400 with the request line NOT in the body"
    (let (port 54743
          _sup (server/start port (fn (_req) {:status 200 :headers {} :body "ok"}))
          resp (raw-response port "ZZ-REFLECT-TOKEN\r\nConnection: close\r\n\r\n"))
      (server/stop port)
      (assert= (includes? resp "400") true)
      (assert= (includes? resp "ZZ-REFLECT-TOKEN") false))))

; Tier-2 (docs/robustness.md): graceful shutdown drains in-flight connections.
(describe "graceful stop lets an in-flight request finish"
  (test "a request already running when stop is called still gets its response"
    (let (me (self)
          port 54743
          _sup (server/start port
                 (fn (_req) (do (sleep 200) {:status 200 :headers {} :body "done"})))
          _c (spawn (report-response port me))
          ; let the request reach the (slow) handler
          _wait (sleep 60)
          ; drains: blocks until the in-flight worker finishes
          _stop (server/stop port)
          resp (receive ([:resp r] r) (after 3000 :timeout)))
      ; the slow handler ran to completion despite stop being called mid-flight
      (assert= (includes? resp "done") true))))

(describe "graceful stop kills a straggler past :shutdown-grace-ms"
  (test "a request still running after the grace window is cut off"
    (let (me (self)
          port 54744
          _sup (server/start port
                 (fn (_req) (do (sleep 1000) {:status 200 :headers {} :body "done"}))
                 nil
                 {:shutdown-grace-ms 100})
          _c (spawn (report-response port me))
          _wait (sleep 60)
          ; grace 100ms < 1000ms handler → worker killed
          _stop (server/stop port)
          resp (receive ([:resp r] r) (after 3000 :timeout)))
      (assert= (includes? resp "done") false))))

; A masked client frame (zero mask key → payload bytes unchanged); fin 0/1, payload ≤125.
(defn ws-frame (fin opcode payload)
  (str (byte->char (+ (* fin 128) opcode))
    (byte->char (+ 128 (string-length payload)))
    "\x00\x00\x00\x00"
    payload))

; Tier-2 end-to-end: a fragmented client message is reassembled across the real socket.
; Before reassembly, the server read loop saw only the first fragment ("Hel") and dropped
; the continuations; now the ws-handler receives the whole message as one payload.
(describe "websocket reassembles a fragmented message end-to-end"
  (test "three frames (FIN=0 text, FIN=0 cont, FIN=1 cont) arrive as one payload"
    (let (me (self)
          port 54751
          _sup (server/start port
                 (fn (_req) {:status 200 :headers {} :body "ok"})
                 (echo-one-frame me))
          client (ws-client-connect port)
          _send (tcp-send client
                  (str (ws-frame 0 1 "Hel") (ws-frame 0 0 "lo ") (ws-frame 1 0 "world")))
          payload (receive ([:got p] p) (after 3000 :timeout)))
      (tcp-close client)
      (server/stop port)
      (assert= payload "Hello world"))))

; Tier-3 (docs/robustness.md): server-side TLS. A full handshake needs a verification-
; skipping client (the runtime's tls-request validates against real roots), so the
; end-to-end handshake is verified out-of-band with `curl -k`; here we smoke-test that
; the TLS bind path (tls-self-signed → :tls config → tls-listen) starts and stops cleanly.
(describe "server/start serves TLS with a self-signed cert"
  (test "a :tls config binds (tls-listen) and stops without error"
    (let ([cert key] (tls-self-signed "localhost")
          port 54761
          sup (server/start port
                (fn (_req) {:status 200 :headers {} :body "ok"})
                nil
                {:tls {:cert cert :key key}}))
      (sleep 100)
      (server/stop port)
      (assert= (nil? sup) false))))
