(defmodule http-request-test (:use http/request) (:use test))

(describe "parse-request-line"
  (test "GET no query"
    (assert= (parse-request-line "GET / HTTP/1.1") [:ok "GET" "/" ""]))
  (test "GET with query"
    (assert= (parse-request-line "GET /search?q=foo HTTP/1.1") [:ok "GET" "/search" "q=foo"]))
  (test "POST path"
    (assert= (parse-request-line "POST /users HTTP/1.1") [:ok "POST" "/users" ""]))
  (test "lowercase method normalized"
    (assert= (parse-request-line "get / HTTP/1.1") [:ok "GET" "/" ""]))
  (test "garbage returns error"
    (let (r (parse-request-line "GARBAGE"))
      (assert= (first r) :error))))

(describe "try-parse: incomplete"
  (test "empty buffer" (assert= (try-parse "") [:incomplete]))
  (test "partial header" (assert= (try-parse "GET / HTTP/1.1\r\n") [:incomplete])))

(describe "try-parse: errors"
  (test "bad request line"
    (let (r (try-parse "GARBAGE\r\n\r\n"))
      (assert= (first r) :error))))

(describe "try-parse: successful GET"
  (test "returns :ok"
    (let (r (try-parse "GET /hello?name=world HTTP/1.1\r\nHost: localhost\r\n\r\n"))
      (assert= (first r) :ok)))
  (test "method"
    (let ([_ req _] (try-parse "GET /hello HTTP/1.1\r\nHost: x\r\n\r\n"))
      (assert= (get req :method) "GET")))
  (test "path"
    (let ([_ req _] (try-parse "GET /hello?x=1 HTTP/1.1\r\nHost: x\r\n\r\n"))
      (assert= (get req :path) "/hello")))
  (test "query"
    (let ([_ req _] (try-parse "GET /p?a=b HTTP/1.1\r\nHost: x\r\n\r\n"))
      (assert= (get req :query) "a=b")))
  (test "params parsed"
    (let ([_ req _] (try-parse "GET /p?name=Alice HTTP/1.1\r\nHost: x\r\n\r\n"))
      (assert= (get (get req :params) "name") "Alice")))
  (test "header keyword-ized"
    (let ([_ req _] (try-parse "GET / HTTP/1.1\r\nContent-Type: text/html\r\n\r\n"))
      (assert= (get (get req :headers) :content-type) "text/html")))
  (test "empty remainder when no pipeline"
    (let ([_ _ rem] (try-parse "GET / HTTP/1.1\r\nHost: x\r\n\r\n"))
      (assert= rem ""))))

(describe "try-parse: POST with body"
  (test "body extracted"
    (let (raw "POST /data HTTP/1.1\r\nContent-Length: 5\r\n\r\nhello"
          [_ req _] (try-parse raw))
      (assert= (get req :body) "hello")))
  (test "remainder empty after full body"
    (let (raw "POST /data HTTP/1.1\r\nContent-Length: 5\r\n\r\nhello"
          [_ _ rem] (try-parse raw))
      (assert= rem "")))
  (test "incomplete when body not yet fully arrived"
    (let (raw "POST /data HTTP/1.1\r\nContent-Length: 100\r\n\r\nshort")
      (assert= (try-parse raw) [:incomplete]))))

(describe "try-parse: pipelined requests"
  (test "remainder is second request"
    (let (raw (str "GET /first HTTP/1.1\r\nHost: x\r\n\r\n"
                "GET /second HTTP/1.1\r\nHost: x\r\n\r\n")
          [_ _ rem] (try-parse raw))
      (assert= rem "GET /second HTTP/1.1\r\nHost: x\r\n\r\n"))))

; Audit hardening — see docs/tcp-http-audit.md (#3 Content-Length, #6 Transfer-Encoding,
; #10 header colon). Each malformed input must NOT crash the worker; it returns :error
; (→ 400) or parses correctly.
(describe "try-parse: chunked Transfer-Encoding"
  (test "decodes a chunked body"
    (let ([tag req _] (try-parse (str "POST / HTTP/1.1\r\nTransfer-Encoding: chunked\r\n\r\n"
                                   "4\r\nWiki\r\n5\r\npedia\r\n0\r\n\r\n")))
      (assert= tag :ok)
      (assert= (get req :body) "Wikipedia")))
  (test "a chunked body missing its terminator is incomplete"
    (assert= (first (try-parse (str "POST / HTTP/1.1\r\nTransfer-Encoding: chunked\r\n\r\n"
                                 "4\r\nWiki\r\n")))
      :incomplete))
  (test "chunk extensions on the size line are ignored"
    (let ([tag req _] (try-parse (str "POST / HTTP/1.1\r\nTransfer-Encoding: chunked\r\n\r\n"
                                   "4;name=val\r\nWiki\r\n0\r\n\r\n")))
      (assert= tag :ok)
      (assert= (get req :body) "Wiki")))
  (test "trailers are consumed and the pipelined remainder preserved"
    (let ([tag req rem] (try-parse (str "POST / HTTP/1.1\r\nTransfer-Encoding: chunked\r\n\r\n"
                                     "4\r\nWiki\r\n0\r\nX-Trailer: y\r\n\r\nNEXT")))
      (assert= tag :ok)
      (assert= (get req :body) "Wiki")
      (assert= rem "NEXT")))
  (test "Transfer-Encoding + Content-Length is rejected (smuggling guard)"
    (assert= (first (try-parse (str "POST / HTTP/1.1\r\nTransfer-Encoding: chunked\r\n"
                                 "Content-Length: 4\r\n\r\nWiki")))
      :error))
  (test "a non-chunked Transfer-Encoding (gzip) is rejected, not mis-framed"
    (assert= (first (try-parse "POST / HTTP/1.1\r\nTransfer-Encoding: gzip\r\n\r\n"))
      :error)))

(describe "try-parse: hardening"
  (test "rejects negative Content-Length (#3 — used to crash on substring)"
    (assert= (first (try-parse "POST / HTTP/1.1\r\nContent-Length: -5\r\n\r\n")) :error))
  (test "rejects non-integer Content-Length (#3)"
    (assert= (first (try-parse "POST / HTTP/1.1\r\nContent-Length: 1.5\r\n\r\n")) :error))
  (test "accepts a valid Content-Length and reads the body"
    (let ([tag req _] (try-parse "POST / HTTP/1.1\r\nContent-Length: 5\r\n\r\nhello"))
      (assert= tag :ok)
      (assert= (get req :body) "hello")))
  (test "header with no space after the colon is kept (#10)"
    (let ([_ req _] (try-parse "GET / HTTP/1.1\r\nHost:localhost\r\n\r\n"))
      (assert= (get (get req :headers) :host) "localhost")))
  (test "rejects conflicting Content-Length (#12)"
    (assert= (first (try-parse (str "POST / HTTP/1.1\r\nContent-Length: 5\r\n"
                                 "Content-Length: 6\r\n\r\nhello")))
      :error))
  (test "duplicate identical Content-Length is accepted (#12)"
    (let ([tag _ _] (try-parse (str "POST / HTTP/1.1\r\nContent-Length: 5\r\n"
                                 "Content-Length: 5\r\n\r\nhello")))
      (assert= tag :ok))))
