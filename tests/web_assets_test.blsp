(defmodule web-assets-test (:use web/assets) (:alias web/static) (:use test))
(require 'hash)

(describe "proc-opts"
  (test "empty when no cwd/env"
    (assert= (proc-opts {:cmd ["x"]}) {}))
  (test "carries cwd"
    (assert= (proc-opts {:cmd ["x"] :cwd "/tmp"}) {:cwd "/tmp"}))
  (test "carries cwd and env"
    (assert= (proc-opts {:cmd ["x"] :cwd "/tmp" :env {"A" "1"}})
      {:cwd "/tmp" :env {"A" "1"}})))

(describe "run-each / build"
  (test "no commands is a no-op"
    (assert= (build {}) nil))
  (test "a zero-exit command succeeds"
    (assert= (build {:build [["sh" "-c" "exit 0"]]}) nil))
  (test "a non-zero exit raises"
    (assert-error (build {:build [["sh" "-c" "exit 3"]]})))
  (test "install runs its commands too"
    (assert= (install {:install [["sh" "-c" "exit 0"]]}) nil)))

(describe "on-output"
  ; No live registry running in the test, so a CSS-reload signal is a safe no-op —
  ; we're asserting it doesn't blow up whether or not the rebuild marker is present.
  (test "marker present is a no-op without a registry"
    (assert= (on-output "Done in 5ms\n" "Done in") nil))
  (test "marker absent is a no-op"
    (assert= (on-output "Rebuilding...\n" "Done in") nil)))

(describe "fingerprint-name"
  (test "inserts the digest before the extension"
    (assert= (fingerprint-name "app.css" "deadbeef") "app.deadbeef.css"))
  (test "keeps subdirectories"
    (assert= (fingerprint-name "css/app.css" "deadbeef") "css/app.deadbeef.css"))
  (test "no extension → append the digest"
    (assert= (fingerprint-name "robots" "deadbeef") "robots.deadbeef")))

(describe "fingerprint"
  (test "writes content-addressed copies and a manifest"
    (let (dir "/tmp/hatch-assets-fp-test"
          _ (try (make-dir dir) (catch _ nil))
          content "body{color:red}"
          _ (spit (str dir "/app.css") content)
          manifest (fingerprint {:dir dir :files ["app.css"]})
          fp (get manifest "app.css"))
      (assert= fp (fingerprint-name "app.css" (substring (hash/sha256 content) 0 8)))
      (assert= (file-exists? (str dir "/" fp)) true)
      (assert= (slurp (str dir "/" fp)) content)
      (assert= (static/parse-manifest (slurp (str dir "/cache-manifest"))) manifest)
      (delete-file (str dir "/app.css"))
      (delete-file (str dir "/" fp))
      (delete-file (str dir "/cache-manifest")))))
