(defmodule web-live-test (:use web/live) (:use web/template) (:use web/conn) (:use test))

(defn client-js-conn ()
  (build {:method "GET" :path "/static/brood_live.js" :query "" :params {} :headers {} :body ""}))

(describe "client-script"
  (test "default src + defer"
    (let (h (render (client-script)))
      (assert= (starts-with? h "<script") true)
      (assert= (includes? h "src=\"/static/brood_live.js\"") true)
      (assert= (includes? h "defer") true)))
  (test "custom src"
    (assert= (includes? (render (client-script "/assets/live.js")) "src=\"/assets/live.js\"") true)))

(describe "status-bar"
  (test "default pill"
    (let (h (render (status-bar)))
      (assert= (includes? h "class=\"brood-status\"") true)
      (assert= (includes? h "reconnecting") true)))
  (test "custom label"
    (assert= (includes? (render (status-bar "offline")) ">offline<") true)))

(describe "live-chrome"
  (test "bundles the client script, status style, and status pill"
    (let (h (render (live-chrome)))
      (assert= (includes? h "src=\"/static/brood_live.js\"") true)
      (assert= (includes? h ".brood-status") true)
      (assert= (includes? h "reconnecting") true)))
  (test "custom client src"
    (assert= (includes? (render (live-chrome "/x.js")) "src=\"/x.js\"") true)))

(describe "status-style"
  (test "style element with the status class"
    (let (h (render (status-style)))
      (assert= (starts-with? h "<style>") true)
      (assert= (includes? h ".brood-status") true))))

(describe "client-js"
  (test "serves the bundled client source"
    (let (js (client-js))
      (assert= (string? js) true)
      (assert= (includes? js "BroodLive") true))))

(describe "client-js-handler"
  (test "serves the client as JS"
    (let (resp ((client-js-handler) (client-js-conn)))
      (assert= (get resp :status) 200)
      (assert= (get (get resp :resp-headers) :content-type) "text/javascript; charset=utf-8")))
  (test "revalidates (no stale cached client)"
    (let (resp ((client-js-handler) (client-js-conn)))
      (assert= (get (get resp :resp-headers) :cache-control) "no-cache"))))

(describe "live--ws-path"
  (test "strips the /live/ws prefix"
    (assert= (web/live/live--ws-path "/live/ws/counter") "/counter"))
  (test "root live path" (assert= (web/live/live--ws-path "/live/ws/") "/"))
  (test "passes non-ws paths through" (assert= (web/live/live--ws-path "/counter") "/counter")))

; One test, run sequentially: registering and looking up both touch the shared
; :hatch-live-routes process, and concurrent tests would race its first-time init
; (a race that can't happen in production — the router registers at load, before any
; connection looks a path up).
(describe "live-route registry"
  (test "register, look up, and miss"
    (do
      (register-live "/reg-test" (fn () {:ok true}) :admin)
      ; its live-session group
      (let (e (lookup-live "/reg-test"))
        ; the registered spec thunk
        (assert= ((get e :spec)) {:ok true})
        (assert= (get e :session) :admin))
      (assert= (lookup-live "/never-registered-xyz") nil))))

; Tier-3 (docs/robustness.md): the route table survives the registry process crashing —
; it mirrors to a supervised vault and re-seeds from it on restart.
(describe "live-route registry survives a crash"
  (test "a registered route is still there after the registry process is killed"
    (do
      (register-live "/crash-test" (fn () {:ok true}) :customer)
      (assert= (get (lookup-live "/crash-test") :session) :customer)
      ; hard-kill the route registry; the supervisor restarts it and it re-seeds from the vault
      (exit (whereis :hatch-live-routes) :kill)
      ; wait for the supervised restart + re-seed (lookup itself also waits out the window)
      (sleep 80)
      (let (e (lookup-live "/crash-test"))
        (assert= (nil? e) false)
        (assert= ((get e :spec)) {:ok true})
        (assert= (get e :session) :customer)))))

(describe "reload-css broadcast"
  ; notify-reload-css fans a [:reload-css] out to every registered session via the
  ; :hatch-live reload registry. Register this test process as a stand-in session, fire
  ; the notify, and confirm the message arrives — the same path the asset watcher drives
  ; on each CSS rebuild. Unregister after so we don't leak into other tests.
  (test "notify-reload-css is a safe no-op before any session registers"
    (assert= (notify-reload-css) nil))
  (test "a registered session receives [:reload-css]"
    (do
      (web/live/live--register (self))
      (notify-reload-css)
      (let (got (receive ([:reload-css] :got) (after 1000 :timeout)))
        (web/live/live--unregister (self))
        (assert= got :got)))))

(describe "send-info"
  ; send-info is the delivery primitive PubSub/Presence build on: it posts an [:info
  ; payload] envelope to a session pid, which the session loop routes to handle-info. Use
  ; this test process as a stand-in session and confirm the envelope arrives intact.
  (test "delivers an [:info payload] envelope to the session pid"
    (do
      (send-info (self) {:topic "room:1" :event "joined"})
      (assert= (receive ([:info payload] payload) (after 1000 :timeout))
        {:topic "room:1" :event "joined"})))
  (test "returns nil and the payload can be any term"
    (let (ret (send-info (self) :ping)
          drained (receive ([:info p] p) (after 1000 :timeout)))
      (assert= ret nil)
      (assert= drained :ping))))

; Inbound WS event params arrive as JSON; the decoder must handle every escape JSON.stringify
; can emit — including \uXXXX (control chars) and the named \b/\f — and must never crash the
; session process on a hostile escape (a lone surrogate, bad hex), falling back to U+FFFD.
(describe "json-decode string escapes"
  (test "named escapes n/r/t/b/f and backslash/quote/slash"
    (assert= (json-decode "\"a\\nb\\tc\\\\d\\\"e\\/f\"") "a\nb\tc\\d\"e/f"))
  (test "\\uXXXX decodes to the codepoint (lowercase and uppercase hex)"
    (assert= (json-decode "\"\\u0041\\u00e9\\u00C9\"") (str "A" (int->char 233) (int->char 201))))
  (test "\\u of a control char round-trips (e.g. tab via \\u0009)"
    (assert= (json-decode "\"x\\u0009y\"") "x\ty"))
  (test "a lone surrogate falls back to U+FFFD instead of crashing"
    (assert= (json-decode "\"\\uD83D\"") (int->char 65533)))
  (test "malformed hex falls back to U+FFFD"
    (assert= (json-decode "\"\\uZZZZ\"") (int->char 65533)))
  (test "\\u inside an object value"
    (assert= (json-decode "{\"k\":\"\\u0041\"}") {"k" "A"})))
