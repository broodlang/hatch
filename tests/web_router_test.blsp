(defmodule web-router-test (:use web/router) (:use web/conn) (:use test))

(defn conn-for (method path)
  (build {:method method :path path :query "" :params {} :headers {} :body ""}))

(describe "path-segments"
  (test "root" (assert= (path-segments "/") nil))
  (test "single" (assert= (path-segments "/foo") (list "foo")))
  (test "nested" (assert= (path-segments "/foo/bar") (list "foo" "bar")))
  (test "no leading /" (assert= (path-segments "foo/bar") (list "foo" "bar"))))

(describe "parse-pattern"
  (test "literal segments"
    (assert= (parse-pattern "/foo/bar") (list "foo" "bar")))
  (test "captures"
    (assert= (parse-pattern "/users/:id") (list "users" :id)))
  (test "multi-capture"
    (assert= (parse-pattern "/a/:b/c/:d") (list "a" :b "c" :d)))
  (test "splat"
    (assert= (parse-pattern "/static/*path") (list "static" [:splat "path"])))
  (test "bare splat captures as splat"
    (assert= (parse-pattern "/files/*") (list "files" [:splat "splat"]))))

(describe "match-path"
  (test "exact match"
    (assert= (match-path ["foo" "bar"] ["foo" "bar"]) {}))
  (test "mismatch"
    (assert= (match-path ["foo"] ["bar"]) nil))
  (test "too short"
    (assert= (match-path ["foo" "bar"] ["foo"]) nil))
  (test "too long"
    (assert= (match-path ["foo"] ["foo" "bar"]) nil))
  (test "capture"
    (assert= (match-path ["users" :id] ["users" "42"]) {"id" "42"}))
  (test "multi-capture"
    (assert= (match-path ["a" :b "c" :d] ["a" "1" "c" "2"]) {"b" "1" "d" "2"}))
  (test "root pattern"
    (assert= (match-path nil nil) {}))
  (test "splat captures remaining segments"
    (assert= (match-path ["static" [:splat "path"]] ["static" "css" "app.css"])
      {"path" "css/app.css"}))
  (test "splat captures a single segment"
    (assert= (match-path ["static" [:splat "path"]] ["static" "x.js"]) {"path" "x.js"}))
  (test "splat captures empty tail"
    (assert= (match-path ["static" [:splat "path"]] ["static"]) {"path" ""})))

(describe "dispatch"
  (test "exact GET route"
    (let (routes [(make-route "GET" "/" (fn (conn) (html-resp conn "<h1>home</h1>")))]
          resp (dispatch routes (conn-for "GET" "/")))
      (assert= (get resp :status) 200)))

  (test "path param captured into params"
    (let (routes [(make-route "GET" "/users/:id" (fn (conn) (html-resp conn (param conn "id"))))]
          resp (dispatch routes (conn-for "GET" "/users/42")))
      (assert= (get resp :resp-body) "42")))

  (test "wrong method returns 404"
    (let (routes [(make-route "GET" "/" (fn (conn) (html-resp conn "ok")))]
          resp (dispatch routes (conn-for "POST" "/")))
      (assert= (get resp :status) 404)))

  (test "no matching route returns 404"
    (let (routes [(make-route "GET" "/foo" (fn (conn) (html-resp conn "foo")))]
          resp (dispatch routes (conn-for "GET" "/bar")))
      (assert= (get resp :status) 404)))

  (test "wildcard method matches any"
    (let (routes [(make-route "*" "/any" (fn (conn) (html-resp conn "ok")))]
          resp (dispatch routes (conn-for "DELETE" "/any")))
      (assert= (get resp :status) 200)))

  (test "string handler result becomes a 200 body"
    (let (routes [(make-route "GET" "/hi" (fn (conn) "hello"))]
          resp (dispatch routes (conn-for "GET" "/hi")))
      (assert= (get resp :status) 200)
      (assert= (get resp :resp-body) "hello")))

  (test "first matching route wins"
    (let (routes [(make-route "GET" "/x" (fn (conn) (html-resp conn "first"))) (make-route "GET"
                                                                                 "/x"
                                                                                 (fn (conn)
                                                                                   (html-resp conn
                                                                                     "second")))]
          resp (dispatch routes (conn-for "GET" "/x")))
      (assert= (get resp :resp-body) "first")))

  (test "splat route captures the rest into params"
    (let (routes [(make-route "GET"
                    "/static/*path"
                    (fn (conn) (html-resp conn (param conn "path"))))]
          resp (dispatch routes (conn-for "GET" "/static/css/app.css")))
      (assert= (get resp :resp-body) "css/app.css")))

  (test "404 body escapes the path (no reflected XSS)"
    (let (routes [(make-route "GET" "/ok" (fn (conn) (html-resp conn "ok")))]
          resp (dispatch routes (conn-for "GET" "/<script>")))
      (assert= (includes? (get resp :resp-body) "<script>") false)
      (assert= (includes? (get resp :resp-body) "&lt;script&gt;") true))))

(describe "live-title"
  (test "single segment" (assert= (live-title "/counter") "Counter"))
  (test "multi segment" (assert= (live-title "/users/online") "Users Online"))
  (test "root is Home" (assert= (live-title "/") "Home"))
  (test "override wins" (assert= (live-title "/counter" "Dashboard") "Dashboard")))

(describe "plist-get"
  (test "present" (assert= (plist-get (list :title "X") :title) "X"))
  (test "absent" (assert= (plist-get (list :a 1) :title) nil)))

(describe "defrouter live-session"
  (defrouter ls-router
    (live-session "admin"
      (get "/admin/page" (fn (conn) "admin page"))
      (get "/admin/info" (fn (conn) "admin info"))))
  (test "a get inside a live-session is an ordinary route"
    (assert= (get (ls-router (conn-for "GET" "/admin/page")) :resp-body) "admin page"))
  (test "every clause in the block routes"
    (assert= (get (ls-router (conn-for "GET" "/admin/info")) :resp-body) "admin info")))

(describe "defrouter macro"
  (defrouter sample-router
    (get "/" (fn (conn) (html-resp conn "home")))
    (get "/users/:id" (fn (conn) (html-resp conn (param conn "id"))))
    (post "/items" (fn (conn) (html-resp conn "created"))))

  (test "GET /"
    (assert= (get (sample-router (conn-for "GET" "/")) :status) 200))
  (test "GET / body"
    (assert= (get (sample-router (conn-for "GET" "/")) :resp-body) "home"))
  (test "GET /users/:id captures id"
    (assert= (get (sample-router (conn-for "GET" "/users/7")) :resp-body) "7"))
  (test "POST /items"
    (assert= (get (sample-router (conn-for "POST" "/items")) :resp-body) "created"))
  (test "unknown route 404"
    (assert= (get (sample-router (conn-for "GET" "/gone")) :status) 404)))

; Plugs for the `through` tests: one enriches the conn, one halts it.
(defn tag-plug (conn) (assign conn :tag "tagged"))
(defn deny-plug (conn) (halt (send-resp conn 403 "denied")))

(describe "defrouter through"
  (defrouter through-router
    (through [tag-plug]
      (get "/ok" (fn (conn) (html-resp conn (or (get-assign conn :tag) "no-tag")))))
    (through [deny-plug]
      (get "/secret" (fn (conn) (html-resp conn "secret"))))
    (get "/open" (fn (conn) (html-resp conn "open"))))

  (test "a non-halting plug runs before the handler and enriches the conn"
    (assert= (get (through-router (conn-for "GET" "/ok")) :resp-body) "tagged"))
  (test "a halting plug short-circuits the handler with its own response"
    (let (resp (through-router (conn-for "GET" "/secret")))
      (assert= (get resp :status) 403)
      (assert= (get resp :resp-body) "denied")))
  (test "routes outside a through group are unaffected"
    (assert= (get (through-router (conn-for "GET" "/open")) :resp-body) "open")))

(describe "defrouter nested groups"
  ; through nests inside live-session — the recursive compiler composes both.
  (defrouter nested-router
    (live-session "admin"
      (through [tag-plug]
        (get "/admin/ok" (fn (conn) (or (get-assign conn :tag) "no-tag"))))))
  (test "a plug inside live-session > through still runs"
    (assert= (get (nested-router (conn-for "GET" "/admin/ok")) :resp-body) "tagged")))
